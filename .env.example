# Copy to .env and fill in. Get a key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Optional: override the default model id (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: address/port of the remote Contract Analyzer AgentOS (defaults below)
# CONTRACT_REMOTE_AGENT_URL=http://localhost:7778
# CONTRACT_REMOTE_PORT=7778
CONTRACT_REMOTE_AGENT_TOKEN=
